generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  password_hash String
  display_name String
  role       String   @default("user")
  created_at DateTime @default(now()) @db.Timestamptz
  last_login DateTime? @db.Timestamptz

  @@index([email])
  @@index([role])
}

model Device {
  id            String   @id @default(uuid()) @db.Uuid
  device_id     String   @unique
  name          String?
  grid          String?
  lat           Float
  lng           Float
  status        String   @default("offline")
  last_seen     DateTime @default(now()) @db.Timestamptz
  signal_strength Int?
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @default(now()) @db.Timestamptz
  events       Event[]
  status_logs  StatusLog[]

  @@index([device_id])
  @@index([status])
  @@index([grid])
  @@index([last_seen])
}

model Event {
  id                String   @id @default(uuid()) @db.Uuid
  device_id         String
  device            Device   @relation(fields: [device_id], references: [device_id], onDelete: Cascade)
  status            String   @default("Active")
  severity          String   @default("Medium")
  location          String?
  grid              String?
  lat               Float
  lng               Float
  start_time        DateTime @default(now()) @db.Timestamptz
  duration         Int?
  notes            String?
  affected_customers Int @default(0)
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @db.Timestamptz

  @@index([device_id])
  @@index([status])
  @@index([severity])
  @@index([start_time])
  @@index([created_at])
  @@index([grid])
}

model StatusLog {
  id         String   @id @default(uuid()) @db.Uuid
  device_id  String
  device    Device   @relation(fields: [device_id], references: [device_id], onDelete: Cascade)
  status    String
  current   Float?
  latitude  Float
  longitude Float
  timestamp DateTime @default(now()) @db.Timestamptz

  @@index([device_id])
  @@index([timestamp])
}